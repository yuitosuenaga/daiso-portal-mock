generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InquiryCategory {
  defect
  order
  system
  other
}

enum InquiryUrgency {
  high
  medium
  low
}

enum InquiryStatus {
  new
  in_progress
  resolved
}

enum InquiryHistoryEntryType {
  claimed
  released
  status_changed
  reply_sent
  requester_message
}

model Company {
  id                     String                  @id @default(cuid())
  name                   String
  country                String
  companyCode            String                  @unique
  createdAt              DateTime                @default(now())
  applicantUsers         ApplicantUser[]
  inquiries              Inquiry[]
  announcementRecipients AnnouncementRecipient[]
}

model ApplicantUser {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  displayName     String
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  createdAt       DateTime @default(now())
  isActive        Boolean  @default(true)
  /// 通知メール・お知らせ表示に用いる言語設定。未設定（既定値）は"en"として扱う。
  preferredLocale String   @default("en")
}

model HelpdeskStaff {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  displayName      String
  createdAt        DateTime  @default(now())
  claimedInquiries Inquiry[]
}

model Inquiry {
  id                     String                @id @default(cuid())
  title                  String                @default("")
  category               InquiryCategory
  urgency                InquiryUrgency
  storeRegion            String
  originalText           String
  originalLanguage       String
  translatedText         String?
  status                 InquiryStatus         @default(new)
  createdAt              DateTime              @default(now())
  companyId              String
  company                Company               @relation(fields: [companyId], references: [id])
  submittedByCompanyName String
  submittedByCountry     String
  claimedByStaffId       String?
  claimedByStaff         HelpdeskStaff?        @relation(fields: [claimedByStaffId], references: [id])
  claimedAt              DateTime?
  attachments            InquiryAttachment[]
  history                InquiryHistoryEntry[]
  /// 申請者が最後にこの問い合わせの詳細画面を開いた時刻（既読時刻）。null=一度も開いていない
  lastReadAt             DateTime?

  @@index([companyId])
}

model InquiryHistoryEntry {
  id          String                  @id @default(cuid())
  inquiryId   String
  inquiry     Inquiry                 @relation(fields: [inquiryId], references: [id])
  type        InquiryHistoryEntryType
  actorName   String
  occurredAt  DateTime
  detail      String?
  attachments InquiryAttachment[]

  @@index([inquiryId])
}

model InquiryAttachment {
  id             String               @id @default(cuid())
  fileName       String
  fileType       String
  fileSize       Int
  dataUrl        String
  inquiryId      String?
  inquiry        Inquiry?             @relation(fields: [inquiryId], references: [id])
  historyEntryId String?
  historyEntry   InquiryHistoryEntry? @relation(fields: [historyEntryId], references: [id])
}

enum AnnouncementCategory {
  maintenance
  policy
  incident
  other
}

enum AnnouncementTargetingScope {
  all
  countries
}

enum AnnouncementStatus {
  draft
  published
}

enum AnnouncementNotificationKind {
  publish
  reminder
}

enum AnnouncementNotificationStatus {
  sent
  failed
  skipped
}

model Announcement {
  id                 String                        @id @default(cuid())
  title              String
  body               String
  category           AnnouncementCategory
  status             AnnouncementStatus            @default(published)
  publishedAt        DateTime?
  actionRequired     Boolean                       @default(false)
  targetingScope     AnnouncementTargetingScope    @default(all)
  targetingCountries String[]                      @default([])
  publishStartDate   DateTime?                     @db.Date
  publishEndDate     DateTime?                     @db.Date
  dueDate            DateTime?                     @db.Date
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  recipientStatuses  AnnouncementRecipientStatus[]
  attachments        AnnouncementAttachment[]
  linkedDocuments    AnnouncementDocumentLink[]
  translations       AnnouncementTranslation[]
  notificationLogs   AnnouncementNotificationLog[]
}

/**
 * お知らせのタイトル・本文を`ja`以外の言語で保持する子テーブル。`ja`（既定言語）の内容は
 * 引き続き`Announcement.title`/`body`が正であり、`locale === "ja"`の行は作らない。
 * `en`の行は作成・編集時に必ず1件存在するようサービス層で保証する。
 */
model AnnouncementTranslation {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  locale         String
  title          String
  body           String

  @@unique([announcementId, locale])
  @@index([announcementId])
}

/**
 * お知らせの公開・リマインド通知メールの送信結果履歴。宛先1件ごとに1行を作成する
 * （履歴は追記のみで、更新・削除は行わない）。
 */
model AnnouncementNotificationLog {
  id             String                         @id @default(cuid())
  announcementId String
  announcement   Announcement                   @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  kind           AnnouncementNotificationKind
  recipientEmail String
  locale         String
  status         AnnouncementNotificationStatus
  errorMessage   String?
  sentAt         DateTime                       @default(now())

  @@index([announcementId])
}

model AnnouncementAttachment {
  id             String       @id @default(cuid())
  fileName       String
  fileType       String
  fileSize       Int
  dataUrl        String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([announcementId])
}

model AnnouncementDocumentLink {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  documentId     String
  document       Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([announcementId, documentId])
  @@index([announcementId])
  @@index([documentId])
}

model AnnouncementRecipient {
  id          String                        @id @default(cuid())
  companyId   String
  company     Company                       @relation(fields: [companyId], references: [id])
  contactName String
  statuses    AnnouncementRecipientStatus[]

  @@index([companyId])
}

model AnnouncementRecipientStatus {
  id             String                @id @default(cuid())
  announcementId String
  announcement   Announcement          @relation(fields: [announcementId], references: [id])
  recipientId    String
  recipient      AnnouncementRecipient @relation(fields: [recipientId], references: [id])
  confirmedAt    DateTime?
  completedAt    DateTime?
  reminderSentAt DateTime?

  @@unique([announcementId, recipientId])
  @@index([announcementId])
}

enum DocumentTargetingScope {
  all
  countries
  companies
}

enum DocumentSourceType {
  upload
  google
}

model Document {
  id                    String                     @id @default(cuid())
  title                 String
  description           String?
  sourceType            DocumentSourceType         @default(upload)
  fileName              String?
  fileType              String?
  fileSize              Int?
  dataUrl               String?
  googleUrl             String?
  googleEmbedUrl        String?
  uploadedAt            DateTime                   @default(now())
  targetingScope        DocumentTargetingScope     @default(all)
  targetingCountries    String[]                   @default([])
  targetingCompanyCodes String[]                   @default([])
  linkedByAnnouncements AnnouncementDocumentLink[]
}

enum FaqCategory {
  inquiry_method
  form_input
  status
  other
}

model Faq {
  id        String      @id @default(cuid())
  category  FaqCategory
  question  String
  answer    String
  createdAt DateTime    @default(now())
}

enum LinkCategory {
  internal
  external
  document
  other
}

model Link {
  id          String       @id @default(cuid())
  title       String
  url         String
  category    LinkCategory
  description String?
  createdAt   DateTime     @default(now())
}

model ReplyTemplate {
  id        String          @id @default(cuid())
  category  InquiryCategory
  name      String
  body      String
  createdAt DateTime        @default(now())
}
