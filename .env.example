# Docker Compose上のPostgreSQL接続情報
POSTGRES_DB=portal_mock
POSTGRES_USER=portal_mock
POSTGRES_PASSWORD=portal_mock
POSTGRES_PORT=5432

# Prismaが参照するDB接続文字列。
# 開発環境（Docker Compose）: 下記のままでよい
# 将来の本番環境（Cloud SQL for PostgreSQL）: Cloud SQL Auth Proxyのソケットパスを指定した接続文字列に差し替える
DATABASE_URL="postgresql://portal_mock:portal_mock@localhost:5432/portal_mock"

# Auth.js（NextAuth）のJWT署名鍵。`openssl rand -base64 32`等で生成した値に置き換える
AUTH_SECRET="replace-with-a-random-base64-secret"

# 本番相当（NODE_ENV=production）で`next start`する場合、Auth.jsはデフォルトで
# リクエストのHostヘッダーを信用しない。Cloud Run等、信頼できるリバースプロキシ配下で
# 動作させる場合はtrueにする（開発環境の`next dev`では不要）。
AUTH_TRUST_HOST=true
